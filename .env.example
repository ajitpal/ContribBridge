# ContribBridge - Environment Variables Example
# Copy this file to .env and fill in your values

# ─── REQUIRED ──────────────────────────────────────────────────
# Get from lingo.dev/dashboard -> Settings -> API Keys
LINGODOTDEV_API_KEY=your_lingo_api_key_here
LINGO_ENGINE_ID=your_engine_id_here

# Fine-grained PAT: Issues (read/write) + Webhooks (write) + Contents (read)
GITHUB_TOKEN=your_github_pat_here

# ─── AUTO-GENERATED / OPTIONAL ──────────────────────────────────
# 32-char hex string (can be generated with 'contribbridge init')
GITHUB_WEBHOOK_SECRET=

# Public URL for webhooks (e.g., https://your-project.railway.app)
# Required if you want the CLI to register hooks automatically
WEBHOOK_URL=http://localhost:4000

# repo names to watch (optional, comma-separated: org/r1,org/r2)
GITHUB_REPO=

# ─── CONFIGURATION ──────────────────────────────────────────────
PORT=4000
TARGET_LOCALE=en
CACHE_TTL=3600
NODE_ENV=development

# ─── PRO / BILLING (Optional) ──────────────────────────────────
# RS256 JWT - required for private repos in open-core model
CONTRIBBRIDGE_LICENSE_KEY=


